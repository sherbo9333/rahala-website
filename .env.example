# Contact form email backend (Resend) — required for /api/contact to send email.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional overrides — sensible defaults are used if omitted (see src/app/api/contact/route.ts):
# CONTACT_TO_EMAIL=info@resalaagency.com
# CONTACT_FROM_EMAIL="Resala Website <no-reply@resalaagency.com>"
#
# Note: CONTACT_FROM_EMAIL must be on a domain verified with Resend
# (https://resend.com/domains) or sending will fail — Resend does not
# allow sending "from" an unverified domain.
